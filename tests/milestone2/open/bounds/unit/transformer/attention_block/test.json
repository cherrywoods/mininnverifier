{
    "command": "bounds",
    "network": "resources/attention_block_network.mininn",
    "inputs": [
        "box",
        "resources/input_0_lb.bin",
        "resources/input_0_ub.bin"
    ],
    "check": "bounds_within_range",
    "output_shapes": [
        [
            4,
            8
        ]
    ],
    "sample_outputs": [
        "resources/sample_outputs_0.bin"
    ],
    "sample_atol": 1e-09,
    "description": "BONUS: IBP bounds for a self-attention block (Q.Kt, softmax, attn.V); reference from auto_LiRPA BoundSoftmax (finite); needs box@box dot + an attention-aware softmax relaxation to match",
    "points": 0,
    "bonus_points": 10,
    "reference_lb": [
        "resources/reference_output_0_lb.bin"
    ],
    "reference_ub": [
        "resources/reference_output_0_ub.bin"
    ],
    "tightness_factor": 1.1
}
