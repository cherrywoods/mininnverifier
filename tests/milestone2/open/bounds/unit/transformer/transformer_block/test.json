{
    "command": "bounds",
    "network": "resources/transformer_block_network.mininn",
    "inputs": [
        "box",
        "resources/input_0_lb.bin",
        "resources/input_0_ub.bin"
    ],
    "check": "bounds_within_range",
    "output_shapes": [
        [
            4,
            8
        ]
    ],
    "sample_outputs": [
        "resources/sample_outputs_0.bin"
    ],
    "sample_atol": 1e-09,
    "description": "BONUS: IBP bounds for a full transformer block (attention + residual/LayerNorm + GELU FFN + residual/LayerNorm); reference from auto_LiRPA BoundSoftmax (finite)",
    "points": 0,
    "bonus_points": 15,
    "reference_lb": [
        "resources/reference_output_0_lb.bin"
    ],
    "reference_ub": [
        "resources/reference_output_0_ub.bin"
    ],
    "tightness_factor": 1.1
}
