{
    "command": "bounds",
    "network": "resources/moons_relu_full_network.mininn",
    "inputs": [
        "box",
        "resources/input_0_lb.bin",
        "resources/input_0_ub.bin"
    ],
    "check": "bounds_within_range",
    "output_shapes": [
        [
            1
        ]
    ],
    "sample_outputs": [
        "resources/sample_outputs_0.bin"
    ],
    "sample_atol": 1e-09,
    "description": "IBP bounds for the moons_relu_full classifier over the committed L-inf box",
    "points": 2,
    "reference_lb": [
        "resources/reference_output_0_lb.bin"
    ],
    "reference_ub": [
        "resources/reference_output_0_ub.bin"
    ],
    "tightness_factor": 1.1
}
