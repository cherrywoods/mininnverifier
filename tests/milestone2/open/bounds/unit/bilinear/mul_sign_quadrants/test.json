{
    "command": "bounds",
    "network": "resources/mul_sign_quadrants_network.mininn",
    "inputs": [
        "box",
        "resources/input_0_lb.bin",
        "resources/input_0_ub.bin",
        "box",
        "resources/input_1_lb.bin",
        "resources/input_1_ub.bin"
    ],
    "check": "bounds_within_range",
    "output_shapes": [
        [
            16
        ]
