    "sample_outputs": [
        "resources/sample_outputs_0.bin"
    ],
    "reference_lb": [
        "resources/reference_output_0_lb.bin"
    ],
    "reference_ub": [
        "resources/reference_output_0_ub.bin"
    ],
    "tightness_factor": 1.1,
    "sample_atol": 1e-09,
    "description": "IBP bounds for box x box multiplication across all sign quadrants (every corner of the 4-corner min/max rule)",
    "points": 4
}
