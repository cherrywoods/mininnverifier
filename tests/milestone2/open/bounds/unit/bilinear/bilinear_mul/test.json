{
    "command": "bounds",
    "network": "resources/bilinear_mul_network.mininn",
    "inputs": [
        "box",
        "resources/input_0_lb.bin",
        "resources/input_0_ub.bin",
        "box",
        "resources/input_1_lb.bin",
        "resources/input_1_ub.bin"
    ],
    "check": "bounds_within_range",
    "output_shapes": [
        [
            16
        ]
    ],
    "sample_outputs": [
        "resources/sample_outputs_0.bin"
    ],
    "sample_atol": 1e-09,
    "description": "IBP bounds for box x box (bilinear) multiplication",
    "points": 4,
    "reference_lb": [
        "resources/reference_output_0_lb.bin"
    ],
    "reference_ub": [
        "resources/reference_output_0_ub.bin"
    ],
    "tightness_factor": 1.1
}
