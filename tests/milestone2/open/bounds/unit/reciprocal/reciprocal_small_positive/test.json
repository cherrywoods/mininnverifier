{
    "command": "bounds",
    "network": "resources/reciprocal_small_positive_network.mininn",
    "inputs": [
        "box",
        "resources/input_0_lb.bin",
        "resources/input_0_ub.bin"
    ],
    "check": "bounds_within_range",
    "output_shapes": [
        [
            16
        ]
    ],
    "sample_outputs": [
        "resources/sample_outputs_0.bin"
    ],
    "reference_lb": [
        "resources/reference_output_0_lb.bin"
    ],
    "reference_ub": [
        "resources/reference_output_0_ub.bin"
    ],
    "tightness_factor": 1.1,
    "sample_atol": 1e-09,
    "description": "IBP bounds for reciprocal over a small-positive box (steep 1/std region: large, numerically sensitive bounds)",
    "points": 2
}
